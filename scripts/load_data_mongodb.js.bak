print('Creating indexes...');

mongoDb.campaigns.createIndex({ id: 1, campaign_type: 1 });
mongoDb.campaigns.createIndex({ channel: 1 });

mongoDb.client_first_purchase_date.createIndex({ client_id: 1 }, { unique: true });

mongoDb.friends.createIndex({ friend1: 1, friend2: 1 });

mongoDb.messages.createIndex({ message_id: 1 }, { unique: true });
mongoDb.messages.createIndex({ campaign_id: 1, message_type: 1 });
mongoDb.messages.createIndex({ client_id: 1 });
mongoDb.messages.createIndex({ sent_at: 1 });

mongoDb.events.createIndex({ user_id: 1 });
mongoDb.events.createIndex({ product_id: 1 });
mongoDb.events.createIndex({ category_code: 'text' });

print('MongoDB load completed successfully.');
