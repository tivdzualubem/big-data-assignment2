      id: { $convert: { input: '$id', to: 'long', onError: null, onNull: null } },
      started_at: { $convert: { input: '$started_at', to: 'date', onError: null, onNull: null } },
      finished_at: { $convert: { input: '$finished_at', to: 'date', onError: null, onNull: null } },
