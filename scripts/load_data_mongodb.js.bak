const fs = require('fs');

const dbName = 'ecommerce';
const mongoDb = db.getSiblingDB(dbName);
const BASE = '/home/teeroyce/big-data-assignment2/data_chunks';

function readJSON(path) {
  return JSON.parse(fs.readFileSync(path, 'utf8'));
}

function fixManifestPath(p) {
  if (!p) return p;

  // Convert old VM path to current local path
  if (p.startsWith('/root/big-data-assignment2/')) {
    return p.replace('/root/big-data-assignment2/', '/home/teeroyce/big-data-assignment2/');
  }

  // If manifest stored relative paths, attach BASE
  if (!p.startsWith('/')) {
    return `${BASE}/${p}`;
  }

  return p;
}

function insertInBatches(collectionName, docs, batchSize = 50) {
  const coll = mongoDb.getCollection(collectionName);

  for (let i = 0; i < docs.length; i += batchSize) {
    const batch = docs.slice(i, i + batchSize);
    coll.insertMany(batch, { ordered: false });
    sleep(50);
  }

  print(`Loaded ${docs.length} documents into ${collectionName}`);
}

print('Dropping old database...');
mongoDb.dropDatabase();

print('Loading small collections...');

// campaigns
const campaignsDocs = readJSON(`${BASE}/small_json/campaigns.json`);
insertInBatches('campaigns', campaignsDocs, 200);

// client_first_purchase_date
const firstPurchaseDocs = readJSON(`${BASE}/small_json/client_first_purchase_date.json`);
insertInBatches('client_first_purchase_date', firstPurchaseDocs, 200);

// friends
print('Loading friends chunks...');
const friendsManifest = readJSON(`${BASE}/friends_json/manifest.json`);
for (let i = 0; i < friendsManifest.length; i++) {
  print(`Loading friends chunk ${i + 1}/${friendsManifest.length} ...`);
  const friendsDocs = readJSON(fixManifestPath(friendsManifest[i]));
  insertInBatches('friends', friendsDocs, 50);
  sleep(200);
}

// messages
print('Loading messages chunks...');
const msgManifest = readJSON(`${BASE}/messages_json/manifest.json`);
for (let i = 0; i < msgManifest.length; i++) {
  print(`Loading messages chunk ${i + 1}/${msgManifest.length} ...`);
  const msgDocs = readJSON(fixManifestPath(msgManifest[i]));
  insertInBatches('messages', msgDocs, 50);
  sleep(200);
}

// events
print('Loading events chunks...');
const evtManifest = readJSON(`${BASE}/events_json/manifest.json`);
for (let i = 0; i < evtManifest.length; i++) {
  print(`Loading events chunk ${i + 1}/${evtManifest.length} ...`);
  const evtDocs = readJSON(fixManifestPath(evtManifest[i]));
  insertInBatches('events', evtDocs, 50);
  sleep(200);
}

print('Converting field types...');

